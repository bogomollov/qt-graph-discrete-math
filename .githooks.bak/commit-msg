#!/bin/sh

msg=$(head -n1 "$1")

regex='^\(feat\|fix\|docs\|style\|refactor\|perf\|test\|build\|ci\|chore\|revert\|hotfix\)\(\([a-z0-9._-]\+\)\)\?: .+'

if ! echo "$msg" | grep -Eq "$regex"; then
  echo "Некорректный формат сообщения"
  echo ""
  echo "Формат: <type>(<scope>): <description>"
  echo ""
  echo ""
  echo "Scope необязателен"
  echo ""
  echo "Допустимые типы:"
  echo "  feat     - новая функциональность"
  echo "  fix      - исправление бага"
  echo "  docs     - документация"
  echo "  style    - форматирование кода"
  echo "  refactor - рефакторинг"
  echo "  perf     - улучшение производительности"
  echo "  test     - тесты"
  echo "  build    - сборка/зависимости"
  echo "  ci       - CI/CD"
  echo "  chore    - служебные изменения"
  echo "  revert   - откат изменений"
  echo "  hotfix   - критическое исправление"
  echo ""
  echo "Примеры:"
  echo "  feat(graph): add vertex creation"
  echo "  fix: prevent duplicate edges"
  echo "  docs: update README"
  echo ""
  exit 1
fi